    {
        "id": "build_valve_cmd",
        "type": "function",
        "z": "tab_plant1",
        "name": "Build Valve Command",
        "func": "// Terima: { mode: 'AUTO'|'MANUAL', state: 'OPEN'|'CLOSED' }\nconst body = msg.payload;\n\nif (!body.mode) {\n  msg.payload = { error: 'mode diperlukan (AUTO atau MANUAL)' };\n  msg.statusCode = 400;\n  return [null, msg];\n}\n\nconst cmd = { mode: body.mode };\nif (body.mode === 'MANUAL') {\n  if (!body.state) {\n    msg.payload = { error: 'state diperlukan saat mode MANUAL (OPEN atau CLOSED)' };\n    msg.statusCode = 400;\n    return [null, msg];\n  }\n  cmd.state = body.state;\n}\n\nmsg.payload = JSON.stringify(cmd);\nmsg.topic   = 'wwtp/plant1/valve/cmd';\nreturn [msg, null];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 360,
        "y": 400,
        "wires": [
            [
                "mqtt_out_valve_cmd"
            ],
            [
                "http_response_error"
            ]
