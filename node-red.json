    {
        "id": "build_dosing_cmd",
        "type": "function",
        "z": "tab_plant1",
        "name": "Build Actuator Command",
        "func": "const body = msg.payload;\nif (!body.device || !body.cmd) {\n  msg.payload = { error: 'device (acid, base, mixer) dan cmd (ON, OFF) diperlukan' };\n  msg.statusCode = 400;\n  return [null, msg];\n}\n\nlet subtopic = '';\nif (body.device === 'acid') subtopic = 'dosing/acid/cmd';\nelse if (body.device === 'base') subtopic = 'dosing/base/cmd';\nelse if (body.device === 'mixer') subtopic = 'mixer/cmd';\nelse {\n  msg.payload = { error: 'device tidak dikenal' };\n  msg.statusCode = 400;\n  return [null, msg];\n}\n\nmsg.payload = JSON.stringify({ cmd: body.cmd });\nmsg.topic   = 'wwtp/plant1/' + subtopic;\nmsg.statusCode = 200;\nreturn [msg, null];",
