    {
        "id": "validate_ph",
        "type": "function",
        "z": "tab_plant1",
        "name": "Validate & Transform pH",
        "func": "let p = msg.payload;\nif (typeof p === 'string') {\n  try { p = JSON.parse(p); }\n  catch (e) { node.warn('JSON parse error: ' + e); return null; }\n}\n\nconst required = ['plant_id', 'sensor_type', 'value', 'unit', 'status'];\nfor (const f of required) {\n  if (p[f] === undefined) { node.warn('Missing: ' + f); return null; }\n}\n\nmsg.payload = {\n  plant_id:    p.plant_id,\n  sensor_type: p.sensor_type,\n  value:       parseFloat(p.value),\n  unit:        p.unit,\n  status:      p.status,\n  is_manual:   Boolean(p.is_manual)\n};\n\nconst SUPABASE_KEY = \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlydHJqZGxneml4dG5qd3pzZmpqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMyMDA2MzUsImV4cCI6MjA4ODc3NjYzNX0.GdQ2J2jxSQXdTB0fAbUiSvemnLJeCSU7W3geHPsBQ2g\";\n\nmsg.headers = {\n  'Content-Type':  'application/json',\n  'Authorization': 'Bearer ' + SUPABASE_KEY,\n  'apikey':        SUPABASE_KEY,\n  'Prefer':        'return=minimal'\n};\n\nnode.warn('SENDING pH: ' + JSON.stringify(msg.payload));\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
